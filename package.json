{
  "name": "fvtt-campaign-builder",
  "title": "World & Campaign Builder for Foundry",
  "version": "1.10.0",
  "type": "module",
  "description": "Create regions, organizations, culture, and other elements of your world, right in Foundry.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dovrosenberg/fvtt-campaign-builder.git"
  },
  "author": "Dov Rosenberg",
  "homepage": "https://github.com/dovrosenberg/fvtt-campaign-builder#readme",
  "main": "main.ts",
  "scripts": {
    "build": "vite build",
    "debug": "vite build --minify=false --mode development",
    "debug:test": "vite build --minify=false --mode test",
    "lint": "eslint --ext .ts,.vue src",
    "linkdata": "ln -s $PWD/dist ~/foundry13data/Data/modules/campaign-builder",
    "tscvue": "vue-tsc --noEmit --skipLibCheck -p ./tsconfig.json",
    "tsc": "tsgo --noEmit --skipLibCheck -p ./tsconfig.json",
    "unlinkdata": "unlink ~/foundry13data/Data/modules/campaign-builder",
    "foundry": "node ~/foundry13/resources/app/main.js --dataPath=/home/dov/foundry13data",
    "updateREST": "rm -rf src/apiClient && npx @openapitools/openapi-generator-cli generate --config=openapi-config.json",
    "docs:generate-version": "node docs/.vitepress/theme/utils/generate-version.cjs",
    "docs:dev": "npm run docs:generate-version && vitepress dev docs",
    "docs:build": "npm run docs:generate-version && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "translate": "node .scripts/translate.cjs",
    "test:rebuild": "playwright test --project=rebuild",
    "test:all": "playwright test --project=all",
    "test": "playwright test --project=headless"
  },
  "devDependencies": {
    "@ethaks/fvtt-quench": "^0.10.0",
    "@faker-js/faker": "^9.3.0",
    "@openapitools/openapi-generator-cli": "^2.21.0",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.56.0",
    "@primevue/auto-import-resolver": "^4.2.5",
    "@types/fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "@types/jquery": "^3.5.32",
    "@types/sinon": "^21.0.0",
    "@types/yaireo__tagify": "^4.27.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@typescript/native-preview": "^7.0.0-dev.20251228.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "css-loader": "^7.1.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^2.9.2",
    "null-loader": "^4.0.1",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "^3.4.2",
    "raw-loader": "^4.0.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-scss": "^4.0.1",
    "sass": "^1.83.0",
    "semver-increment": "^1.0.1",
    "sinon": "^20.0.0",
    "source-map-loader": "^5.0.0",
    "string-replace-loader": "^3.1.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.3",
    "unplugin-vue-components": "^0.28.0",
    "vite": "^6.1.6",
    "vite-plugin-env-compatible": "^2.0.1",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitepress": "^1.6.3",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "@imengyu/vue3-context-menu": "^1.4.4",
    "@primeuix/themes": "^2.0.3",
    "@yaireo/tagify": "^4.34.0",
    "minisearch": "^7.1.2",
    "pinia": "^3.0.4",
    "playwright": "^1.56.0",
    "primevue": "^4.2.5",
    "vis-network": "^10.0.2",
    "vis-timeline": "^8.5.0",
    "vue": "^3.5.13"
  }
}
